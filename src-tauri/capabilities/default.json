{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Base capabilities. The Vault FS scope is granted dynamically after the user picks a folder — NOT a static path here (NFR-SEC-003).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "fs:scope",
      "allow": []
    },
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-mkdir",
    "fs:allow-watch"
  ]
}
